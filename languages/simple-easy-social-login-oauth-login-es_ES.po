msgid "Simple Easy Social Login"
msgstr "Inicio de Sesión Social Simple y Fácil"

msgid "SE Social Login"
msgstr "SE Inicio de Sesión Social"

msgid "Simple Easy Social Login – Setting"
msgstr "Inicio de Sesión Social Simple y Fácil – Configuración"

msgid "Setting"
msgstr "Configuración"

msgid "Providers"
msgstr "Proveedores"

msgid "Enter OAuth credentials for each provider."
msgstr "Introduzca las credenciales OAuth para cada proveedor."

msgid "%s Client ID"
msgstr "ID de Cliente %s"

msgid "%s Client Secret"
msgstr "Secreto de Cliente %s"

msgid "Client ID"
msgstr "ID de Cliente"

msgid "Client Secret"
msgstr "Secreto de Cliente"

msgid "App ID"
msgstr "ID de App"

msgid "App Secret"
msgstr "Secreto de App"

msgid "REST API Key"
msgstr "Clave REST API"

msgid "Channel ID"
msgstr "ID de Canal"

msgid "Channel Secret"
msgstr "Secreto de Canal"

msgid "App Key"
msgstr "Clave de App"

msgid "Login"
msgstr "Iniciar sesión"

msgid "Post-login Redirect"
msgstr "Redirección después de iniciar sesión"

msgid "Redirect to"
msgstr "Redirigir a"

msgid "Dashboard (wp-admin)"
msgstr "Panel de control (wp-admin)"

msgid "Profile page (wp-admin/profile.php)"
msgstr "Página de perfil (wp-admin/profile.php)"

msgid "Front page (home) — Default"
msgstr "Página principal (home) — Predeterminado"

msgid "Custom URL"
msgstr "URL personalizada"

msgid ""
"When 'Custom URL' is selected, users are redirected to this address after "
"login."
msgstr ""
"Cuando se selecciona «URL personalizada», los usuarios son redirigidos a "
"esta dirección después de iniciar sesión."

msgid "Debug Logging"
msgstr "Registro de depuración"

msgid "Enable logging"
msgstr "Habilitar registro"

msgid "On"
msgstr "Activado"

msgid "Off"
msgstr "Desactivado"

msgid "Writes to wp-content/SESLP-debug.log when enabled."
msgstr "Cuando está habilitado, escribe en wp-content/SESLP-debug.log."

msgid "Logger Timezone"
msgstr "Zona horaria del registro"

msgid "Choose timestamp format for debug logs."
msgstr "Elija el formato de marca de tiempo para los registros de depuración."

msgid "UI"
msgstr "UI"

msgid "Login buttons layout"
msgstr "Diseño de los botones de inicio de sesión"

msgid "List (logo + text, vertical)"
msgstr "Lista (logo + texto, vertical)"

msgid "Icons only (horizontal)"
msgstr "Solo iconos (horizontal)"

msgid ""
"When icons-only is selected, only provider logos are shown in a horizontal "
"row."
msgstr ""
"Cuando se selecciona «Solo iconos», solo se muestran los logotipos de los "
"proveedores en una fila horizontal."

msgid "Save Changes"
msgstr "Guardar cambios"

msgid "Social Login with:"
msgstr "Inicio de sesión social con:"

msgid ""
"This email is already registered on this site. Please sign in with the "
"originally linked method (username/password or the same social provider)."
msgstr ""
"Este correo electrónico ya está registrado en este sitio. Por favor, inicia "
"sesión con el método vinculado originalmente (usuario/contraseña o el mismo "
"proveedor social)."

msgid ""
"Your session has expired or the login attempt was invalid. Please try again."
msgstr ""
"Tu sesión ha expirado o el intento de inicio de sesión no es válido. Por "
"favor, inténtalo de nuevo."

msgid "Failed to obtain an access token from the provider. Please try again."
msgstr ""
"No se pudo obtener un token de acceso del proveedor. Por favor, inténtalo de "
"nuevo."

msgid ""
"A social login error occurred while communicating with the provider. Please "
"try again."
msgstr ""
"Ocurrió un error de inicio de sesión social al comunicarse con el proveedor. "
"Por favor, inténtalo de nuevo."

msgid "Social login failed. Please try again."
msgstr "El inicio de sesión social falló. Por favor, inténtalo de nuevo."

msgid "The requested social login provider is invalid."
msgstr "El proveedor de inicio de sesión social solicitado no es válido."

msgid "This social login provider is not allowed on this site."
msgstr ""
"Este proveedor de inicio de sesión social no está permitido en este sitio."

msgid ""
"This social login provider is not configured correctly. Please contact the "
"site administrator."
msgstr ""
"Este proveedor de inicio de sesión social no está configurado correctamente. "
"Por favor, contacta con el administrador del sitio."

msgid ""
"We could not retrieve an email address from the provider. Please use another "
"login method or contact the site administrator."
msgstr ""
"No pudimos obtener una dirección de correo electrónico del proveedor. Usa "
"otro método de inicio de sesión o contacta con el administrador del sitio."

msgid "We could not link your social account to this site. Please try again."
msgstr ""
"No pudimos vincular tu cuenta social a este sitio. Por favor, inténtalo de "
"nuevo."

msgid ""
"New account creation through social login is currently disabled on this site."
msgstr ""
"La creación de nuevas cuentas mediante inicio de sesión social está "
"actualmente deshabilitada en este sitio."

msgid "Need help? Follow %s"
msgstr "¿Necesitas ayuda? Consulta %s"

msgid "this documentation page"
msgstr "esta página de documentación"

msgid "Settings saved."
msgstr "Configuración guardada."

msgid "Data removal"
msgstr "Eliminación de datos"

msgid "Delete plugin data on uninstall"
msgstr "Eliminar datos del plugin al desinstalar"

msgid ""
"If checked, plugin options, transients, and user meta created by this plugin "
"will be removed when you uninstall."
msgstr ""
"Si se marca, al desinstalar se eliminarán las opciones, transients y "
"metadatos de usuario creados por este plugin."

msgid "Deep clean"
msgstr "Limpieza profunda"

msgid "Also drop custom tables / logs"
msgstr "Eliminar también tablas/registros personalizados"

msgid "Drops tables like seslp_login_logs if present. Irreversible."
msgstr "Elimina tablas como seslp_login_logs si existen. No se puede deshacer."

msgid "Uninstall Options"
msgstr "Opciones de desinstalación"

msgid "UTC"
msgstr "UTC"

msgid "WordPress Local"
msgstr "Hora local de WordPress"

msgid "Both"
msgstr "Ambos"

msgid "This feature is available on %s and above."
msgstr "Esta función está disponible en el plan %s o superior."

msgid "This section is available on %s."
msgstr "Esta sección está disponible en el plan %s."

msgid "See plans"
msgstr "Ver planes"

msgid "Guide"
msgstr "Guía"

msgid "You do not have sufficient permissions to access this page."
msgstr "No tienes permisos suficientes para acceder a esta página."

msgid "SESLP Guide"
msgstr "Guía de SESLP"

msgid "Guide not found"
msgstr "No se encontró la guía."

msgid "Please add a localized Markdown file under assets/md/{locale}.md"
msgstr "Añade un archivo Markdown localizado en assets/md/{locale}.md"

msgid "Shortcode"
msgstr "Código corto"

msgid "Guide content is not available."
msgstr "No se puede cargar el contenido de la guía."

msgid "Show or hide secret"
msgstr "Mostrar u ocultar el secreto"

msgid "Launch Promotion (%s)"
msgstr "Promoción de lanzamiento (%s)"

msgid "Valid until February 2026."
msgstr "Válido hasta febrero de 2026."

msgid "Get <strong>%1$s OFF PRO features</strong> (%2$s)."
msgstr "Obtén <strong>%1$s de descuento en las funciones PRO</strong> (%2$s)."

msgid "Upgrade to PRO & Apply Coupon"
msgstr "Actualizar a PRO y aplicar cupón"

msgid "General Settings"
msgstr "Configuración General"

msgid "Automatic User Creation"
msgstr "Creación Automática de Usuarios"

msgid ""
"Automatically create a new user account when logging in with social provider"
msgstr ""
"Crear automáticamente una nueva cuenta de usuario al iniciar sesión con un "
"proveedor social"

msgid ""
"If disabled, only existing users with the same email can log in via social "
"login. Recommended to keep enabled."
msgstr ""
"Si se desactiva, solo los usuarios existentes con el mismo correo "
"electrónico podrán iniciar sesión mediante login social. Se recomienda "
"mantenerlo activado."

msgid "%s Login"
msgstr "Inicio de sesión con %s"
