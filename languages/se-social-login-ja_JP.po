msgid "Simple Easy Social Login"
msgstr "シンプル イージー ソーシャル ログイン"

msgid "SE Social Login"
msgstr "SE ソーシャル ログイン"

msgid "Simple Easy Social Login – Setting"
msgstr "シンプル イージー ソーシャル ログイン – 設定"

msgid "Setting"
msgstr "設定"

msgid "Providers"
msgstr "プロバイダー"

msgid "Enter OAuth credentials for each provider."
msgstr "各プロバイダーのOAuth認証情報を入力してください。"

msgid "%s Client ID"
msgstr "%s クライアント ID"

msgid "%s Client Secret"
msgstr "%s クライアント シークレット"

msgid "Client ID"
msgstr "クライアント ID"

msgid "Client Secret"
msgstr "クライアント シークレット"

msgid "App ID"
msgstr "アプリ ID"

msgid "App Secret"
msgstr "アプリ シークレット"

msgid "REST API Key"
msgstr "REST API Key"

msgid "Channel ID"
msgstr "チャンネル ID"

msgid "Channel Secret"
msgstr "チャンネル シークレット"

msgid "App Key"
msgstr "アプリ Key"

msgid "Login"
msgstr "ログイン"

msgid "Post-login Redirect"
msgstr "ログイン後リダイレクト"

msgid "Redirect to"
msgstr "リダイレクト先"

msgid "Dashboard (wp-admin)"
msgstr "ダッシュボード (wp-admin)"

msgid "Profile page (wp-admin/profile.php)"
msgstr "プロフィールページ (wp-admin/profile.php)"

msgid "Front page (home) — Default"
msgstr "フロントページ (ホーム) — デフォルト"

msgid "Custom URL"
msgstr "ユーザー定義 URL"

msgid "When 'Custom URL' is selected, users are redirected to this address after login."
msgstr "「ユーザー定義 URL」が選択された場合、ログイン後にこのアドレスにリダイレクトされます。"

msgid "Debug Logging"
msgstr "デバッグ ロギング"

msgid "Enable logging"
msgstr "ロギングを有効化"

msgid "On"
msgstr "オン"

msgid "Off"
msgstr "オフ"

msgid "Writes to wp-content/SESLP-debug.log when enabled."
msgstr "有効化されると、wp-content/SESLP-debug.log に書き込まれます。"

msgid "Logger Timezone"
msgstr "ロガー タイムゾーン"

msgid "Choose timestamp format for debug logs."
msgstr "デバッグログのタイムスタンプ形式を選択してください。"

msgid "UI"
msgstr "UI"

msgid "Login buttons layout"
msgstr "ログインボタンのレイアウト"

msgid "List (logo + text, vertical)"
msgstr "リスト (ロゴ + テキスト、縦)"

msgid "Icons only (horizontal)"
msgstr "アイコンのみ (横)"

msgid "When icons-only is selected, only provider logos are shown in a horizontal row."
msgstr "アイコンのみが選択された場合、プロバイダーロゴのみが横に表示されます。"

msgid "Save Changes"
msgstr "変更を保存"

msgid "Social Login with:"
msgstr "ソーシャル ログイン:"

msgid "This email is already registered on this site. Please sign in with the originally linked method (username/password or the same social provider)."
msgstr "このメールは既にこのサイトに登録されています。元々リンクされた方法（ユーザー名/パスワード、または同じソーシャルプロバイダー）でサインインしてください。"

msgid "Your session has expired or the login attempt was invalid. Please try again."
msgstr "セッションの有効期限が切れたか、ログイン試行が無効です。もう一度お試しください。"

msgid "An unknown error occurred. Please try again."
msgstr "不明なエラーが発生しました。もう一度お試しください。"

msgid "Failed to obtain access token from the provider. Please try again."
msgstr "プロバイダーからアクセストークンを取得できませんでした。もう一度お試しください。"

msgid "Failed to fetch your profile information from the provider. Please try again."
msgstr "プロバイダーからプロフィール情報を取得できませんでした。もう一度お試しください。"

msgid "Need help? Follow %s"
msgstr "ヘルプが必要ですか？%s をご覧ください"

msgid "this documentation page"
msgstr "このドキュメントページ"

msgid "Settings saved."
msgstr "設定が保存されました。"

msgid "Data removal"
msgstr "データ削除"

msgid "Delete plugin data on uninstall"
msgstr "アンインストール時にプラグインデータを削除"

msgid "If checked, plugin options, transients, and user meta created by this plugin will be removed when you uninstall."
msgstr "選択すると、このプラグインによって作成されたオプション、トランジェント、ユーザーメタがアンインストール時に削除されます。"

msgid "Deep clean"
msgstr "完全削除"

msgid "Also drop custom tables / logs"
msgstr "カスタムテーブル/ログも削除"

msgid "Drops tables like seslp_login_logs if present. Irreversible."
msgstr "seslp_login_logs のようなテーブルが存在する場合、削除されます。元に戻せません。"

msgid "Uninstall Options"
msgstr "アンインストールオプション"

msgid "UTC"
msgstr "UTC"

msgid "WordPress Local"
msgstr "WordPressローカル"

msgid "Both"
msgstr "両方"

msgid "This feature is available on %s and above."
msgstr "この機能は%sプラン以上で利用できます。"

msgid "This section is available on %s."
msgstr "このセクションは%sプランで利用可能です。"

msgid "See plans"
msgstr "プランを見る"

msgid "Guide"
msgstr "ガイド"

msgid "You do not have sufficient permissions to access this page."
msgstr "このページにアクセスする権限がありません。"

msgid "SESLP Guide"
msgstr "SESLP ガイド"

msgid "Guide not found"
msgstr "ガイドが見つかりません"

msgid "Please add a localized Markdown file under assets/md/{locale}.md"
msgstr "assets/md/{locale}.md に対象言語の Markdown ファイルを追加してください"

msgid "Shortcode"
msgstr "ショートコード"

msgid "Guide content is not available."
msgstr "ガイド内容を読み込むことができません。"
