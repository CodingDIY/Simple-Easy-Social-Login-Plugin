msgid "Simple Easy Social Login"
msgstr "심플 이지 소셜 로그인"

msgid "SE Social Login"
msgstr "SE 소셜 로그인"

msgid "Simple Easy Social Login – Setting"
msgstr "심플 이지 소셜 로그인 – 설정"

msgid "Setting"
msgstr "설정"

msgid "Providers"
msgstr "제공자"

msgid "Enter OAuth credentials for each provider."
msgstr "각 제공자의 OAuth 자격 증명을 입력하세요."

msgid "%s Client ID"
msgstr "%s 클라이언트 ID"

msgid "%s Client Secret"
msgstr "%s 클라이언트 시크릿"

msgid "Client ID"
msgstr "클라이언트 ID"

msgid "Client Secret"
msgstr "클라이언트 시크릿"

msgid "App ID"
msgstr "앱 ID"

msgid "App Secret"
msgstr "앱 시크릿"

msgid "REST API Key"
msgstr "REST API 키"

msgid "Channel ID"
msgstr "채널 ID"

msgid "Channel Secret"
msgstr "채널 시크릿"

msgid "App Key"
msgstr "앱 Key"

msgid "Login"
msgstr "로그인"

msgid "Post-login Redirect"
msgstr "로그인 후 리디렉션"

msgid "Redirect to"
msgstr "리디렉션 대상"

msgid "Dashboard (wp-admin)"
msgstr "대시보드 (wp-admin)"

msgid "Profile page (wp-admin/profile.php)"
msgstr "프로필 페이지 (wp-admin/profile.php)"

msgid "Front page (home) — Default"
msgstr "첫 페이지 (홈) — 기본값"

msgid "Custom URL"
msgstr "사용자정의 URL"

msgid "When 'Custom URL' is selected, users are redirected to this address after login."
msgstr "'사용자정의 URL'이 선택되면, 로그인 후 이 주소로 리디렉션됩니다."

msgid "Debug Logging"
msgstr "디버그 로깅"

msgid "Enable logging"
msgstr "로깅 활성화"

msgid "On"
msgstr "켜기"

msgid "Off"
msgstr "끄기"

msgid "Writes to wp-content/SESLP-debug.log when enabled."
msgstr "활성화되면 wp-content/SESLP-debug.log에 기록됩니다."

msgid "Logger Timezone"
msgstr "로거 시간대"

msgid "Choose timestamp format for debug logs."
msgstr "디버그 로그의 타임스탬프 형식을 선택하세요."

msgid "UI"
msgstr "UI"

msgid "Login buttons layout"
msgstr "로그인 버튼 레이아웃"

msgid "List (logo + text, vertical)"
msgstr "목록형 (로고 + 텍스트, 세로)"

msgid "Icons only (horizontal)"
msgstr "아이콘만 (가로)"

msgid "When icons-only is selected, only provider logos are shown in a horizontal row."
msgstr "아이콘만 선택되면, 제공자 로고만 가로로 표시됩니다."

msgid "Save Changes"
msgstr "변경 사항 저장"

msgid "Social Login with:"
msgstr "소셜 로그인:"

msgid "This email is already registered on this site. Please sign in with the originally linked method (username/password or the same social provider)."
msgstr "이 이메일은 이미 이 사이트에 등록되어 있습니다. 원래 연결된 방법(사용자 이름/비밀번호 또는 동일한 소셜 제공자)으로 로그인하세요."

msgid "Your session has expired or the login attempt was invalid. Please try again."
msgstr "세션이 만료되었거나 로그인 시도가 유효하지 않습니다. 다시 시도하세요."

msgid "An unknown error occurred. Please try again."
msgstr "알 수 없는 오류가 발생했습니다. 다시 시도하세요."

msgid "Failed to obtain access token from the provider. Please try again."
msgstr "제공자로부터 액세스 토큰을 가져오지 못했습니다. 다시 시도하세요."

msgid "Failed to fetch your profile information from the provider. Please try again."
msgstr "제공자로부터 프로필 정보를 가져오지 못했습니다. 다시 시도하세요."

msgid "Need help? Follow %s"
msgstr "도움이 필요하세요? %s를 참고 하세요"

msgid "this documentation page"
msgstr "이 문서 페이지"

msgid "Settings saved."
msgstr "설정이 저장되었습니다."

msgid "Data removal"
msgstr "데이터 제거"

msgid "Delete plugin data on uninstall"
msgstr "플러그인 삭제 시 데이터 제거"

msgid "If checked, plugin options, transients, and user meta created by this plugin will be removed when you uninstall."
msgstr "선택하면 이 플러그인이 생성한 옵션, 트랜지언트, 사용자 메타가 삭제 시 제거됩니다."

msgid "Deep clean"
msgstr "완전 삭제"

msgid "Also drop custom tables / logs"
msgstr "커스텀 테이블/로그도 삭제"

msgid "Drops tables like seslp_login_logs if present. Irreversible."
msgstr "테이블이 seslp_login_logs 같이 되어 있으면 삭제됩니다. 되돌릴 수 없습니다."

msgid "Uninstall Options"
msgstr "삭제 옵션"

msgid "UTC"
msgstr "UTC"

msgid "WordPress Local"
msgstr "워드프레스 로컬"

msgid "Both"
msgstr "둘 다"

msgid "This feature is available on %s and above."
msgstr "%s 이상 플랜에서 사용 가능합니다."

msgid "This section is available on %s."
msgstr "%s 플랜에서만 이용할 수 있습니다."

msgid "See plans"
msgstr "플랜 보기"

msgid "Guide"
msgstr "가이드"

msgid "You do not have sufficient permissions to access this page."
msgstr "이 페이지에 접근할 수 있는 권한이 없습니다."

msgid "SESLP Guide"
msgstr "SESLP 가이드"

msgid "Guide not found"
msgstr "가이드를 찾을 수 없습니다."

msgid "Please add a localized Markdown file under assets/md/{locale}.md"
msgstr "해당 언어의 Markdown 파일을 assets/md/{locale}.md 위치에 추가해주세요"

msgid "Shortcode"
msgstr "숏코드"
