msgid "Simple Easy Social Login"
msgstr "Einfaches Soziales Login"

msgid "SE Social Login"
msgstr "SE Soziales Login"

msgid "Simple Easy Social Login – Setting"
msgstr "Einfaches Soziales Login – Einstellung"

msgid "Setting"
msgstr "Einstellung"

msgid "Providers"
msgstr "Anbieter"

msgid "Enter OAuth credentials for each provider."
msgstr "Geben Sie die OAuth-Anmeldedaten für jeden Anbieter ein."

msgid "%s Client ID"
msgstr "%s Client-ID"

msgid "%s Client Secret"
msgstr "%s Client-Geheimnis"

msgid "Client ID"
msgstr "Client-ID"

msgid "Client Secret"
msgstr "Client-Geheimnis"

msgid "App ID"
msgstr "App-ID"

msgid "App Secret"
msgstr "App-Geheimnis"

msgid "REST API Key"
msgstr "REST API-Schlüssel"

msgid "Channel ID"
msgstr "Kanal-ID"

msgid "Channel Secret"
msgstr "Kanal-Geheimnis"

msgid "App Key"
msgstr "App-Schlüssel"

msgid "Login"
msgstr "Anmelden"

msgid "Post-login Redirect"
msgstr "Weiterleitung nach Anmeldung"

msgid "Redirect to"
msgstr "Weiterleiten zu"

msgid "Dashboard (wp-admin)"
msgstr "Dashboard (wp-admin)"

msgid "Profile page (wp-admin/profile.php)"
msgstr "Profilseite (wp-admin/profile.php)"

msgid "Front page (home) — Default"
msgstr "Startseite (Home) — Standard"

msgid "Custom URL"
msgstr "Benutzerdefinierte URL"

msgid ""
"When 'Custom URL' is selected, users are redirected to this address after "
"login."
msgstr ""
"Wenn „Benutzerdefinierte URL“ ausgewählt ist, werden Benutzer nach der "
"Anmeldung zu dieser Adresse weitergeleitet."

msgid "Debug Logging"
msgstr "Debug-Protokollierung"

msgid "Enable logging"
msgstr "Protokollierung aktivieren"

msgid "On"
msgstr "Ein"

msgid "Off"
msgstr "Aus"

msgid "Writes to wp-content/SESLP-debug.log when enabled."
msgstr "Wenn aktiviert, wird in wp-content/SESLP-debug.log geschrieben."

msgid "Logger Timezone"
msgstr "Logger-Zeitzone"

msgid "Choose timestamp format for debug logs."
msgstr "Wählen Sie das Zeitstempelformat für Debug-Protokolle."

msgid "UI"
msgstr "UI"

msgid "Login buttons layout"
msgstr "Layout der Anmelde-Schaltflächen"

msgid "List (logo + text, vertical)"
msgstr "Liste (Logo + Text, vertikal)"

msgid "Icons only (horizontal)"
msgstr "Nur Symbole (horizontal)"

msgid ""
"When icons-only is selected, only provider logos are shown in a horizontal "
"row."
msgstr ""
"Wenn „Nur Symbole“ ausgewählt ist, werden nur Anbieter-Logos in einer "
"horizontalen Reihe angezeigt."

msgid "Save Changes"
msgstr "Änderungen speichern"

msgid "Social Login with:"
msgstr "Soziales Login mit:"

msgid ""
"This email is already registered on this site. Please sign in with the "
"originally linked method (username/password or the same social provider)."
msgstr ""
"Diese E-Mail ist bereits auf dieser Website registriert. Bitte melden Sie "
"sich mit der ursprünglich verknüpften Methode (Benutzername/Passwort oder "
"derselbe soziale Anbieter) an."

msgid ""
"Your session has expired or the login attempt was invalid. Please try again."
msgstr ""
"Ihre Sitzung ist abgelaufen oder der Anmeldeversuch war ungültig. Bitte "
"versuchen Sie es erneut."

msgid "An unknown error occurred. Please try again."
msgstr "Ein unbekannter Fehler ist aufgetreten. Bitte versuchen Sie es erneut."

msgid "Failed to obtain access token from the provider. Please try again."
msgstr ""
"Zugriffstoken vom Anbieter konnte nicht abgerufen werden. Bitte versuchen "
"Sie es erneut."

msgid ""
"Failed to fetch your profile information from the provider. Please try again."
msgstr ""
"Ihre Profildaten konnten vom Anbieter nicht abgerufen werden. Bitte "
"versuchen Sie es erneut."

msgid "Need help? Follow %s"
msgstr "Brauchen Sie Hilfe? Folgen Sie %s"

msgid "this documentation page"
msgstr "dieser Dokumentationsseite"

msgid "Settings saved."
msgstr "Einstellungen gespeichert."

msgid "Data removal"
msgstr "Datenentfernung"

msgid "Delete plugin data on uninstall"
msgstr "Plugindaten beim Deinstallieren löschen"

msgid ""
"If checked, plugin options, transients, and user meta created by this plugin "
"will be removed when you uninstall."
msgstr ""
"Wenn aktiviert, werden beim Deinstallieren die von diesem Plugin erstellten "
"Optionen, Transients und Benutzermetadaten entfernt."

msgid "Deep clean"
msgstr "Gründliche Bereinigung"

msgid "Also drop custom tables / logs"
msgstr "Benutzerdefinierte Tabellen/Logs ebenfalls löschen"

msgid "Drops tables like seslp_login_logs if present. Irreversible."
msgstr ""
"Tabellen wie seslp_login_logs werden gelöscht, falls vorhanden. Nicht "
"umkehrbar."

msgid "Uninstall Options"
msgstr "Deinstallationsoptionen"

msgid "UTC"
msgstr "UTC"

msgid "WordPress Local"
msgstr "WordPress Lokalzeit"

msgid "Both"
msgstr "Beide"

msgid "This feature is available on %s and above."
msgstr "Diese Funktion ist ab dem %s-Plan verfügbar."

msgid "This section is available on %s."
msgstr "Dieser Abschnitt ist im %s-Plan verfügbar."

msgid "See plans"
msgstr "Pläne anzeigen"

msgid "Guide"
msgstr "Anleitung"

msgid "You do not have sufficient permissions to access this page."
msgstr ""
"Sie haben keine ausreichenden Berechtigungen, um auf diese Seite zuzugreifen."

msgid "SESLP Guide"
msgstr "SESLP-Anleitung"

msgid "Guide not found"
msgstr "Anleitung wurde nicht gefunden."

msgid "Please add a localized Markdown file under assets/md/{locale}.md"
msgstr ""
"Bitte fügen Sie eine lokalisierte Markdown-Datei unter assets/md/{locale}.md "
"hinzu"

msgid "Shortcode"
msgstr "Shortcode"

msgid "Guide content is not available."
msgstr "Der Leitfadeninhalt kann nicht geladen werden."

msgid "Show or hide secret"
msgstr "Geheimnis anzeigen/ausblenden"

msgid "Launch Promotion (%s)"
msgstr "Einführungsaktion (%s)"

msgid "Valid until February 2026."
msgstr "Gültig bis Februar 2026."

msgid "Get <strong>%1$s OFF PRO features</strong> (%2$s)."
msgstr "Erhalten Sie <strong>%1$s Rabatt auf PRO-Funktionen</strong> (%2$s)."

msgid "Upgrade to PRO & Apply Coupon"
msgstr "Auf PRO upgraden & Gutschein anwenden"

msgid "General Settings"
msgstr "Allgemeine Einstellungen"

msgid "Automatic User Creation"
msgstr "Automatische Benutzererstellung"

msgid ""
"Automatically create a new user account when logging in with social provider"
msgstr ""
"Beim Login mit einem Social Provider automatisch ein neues Benutzerkonto "
"erstellen"

msgid ""
"If disabled, only existing users with the same email can log in via social "
"login. Recommended to keep enabled."
msgstr ""
"Wenn deaktiviert, können nur bestehende Benutzer mit derselben E-Mail-"
"Adresse über Social Login anmelden. Es wird empfohlen, diese Option "
"aktiviert zu lassen."
